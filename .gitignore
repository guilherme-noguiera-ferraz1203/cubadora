# Artefatos e dados locais (não versionar)
__pycache__/
*.pyc
*.pyo

# Dados/persistência do equipamento e do servidor de frota
*.db
data/
fleet-data/
fleet/packages/
bkp/

# Config específica de cada equipamento (use config.example.yaml como base)
config.yaml
cfg_*.yaml

# Override de compose específico do servidor/VPS (não versionar)
docker-compose.override.yml

# Chaves SSH dos tuneis reversos (geradas em runtime, especificas da VPS)
tunnel-keys/
sshd-host-keys/

# Build de documentos e pacotes
_docbuild/node_modules/
_docbuild/package*.json
*.docx
*.zip

# Logs
*.log
